{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "CopilotDigest": {
    "Copilot": {
      "Token": "<YOUR_GITHUB_TOKEN>",
      "ApiUrl": "https://models.inference.ai.azure.com",
      "Model": "gpt-4o",
      "MaxTokens": 1000
    },
    "Email": {
      "SmtpHost": "smtp.gmail.com",
      "SmtpPort": 587,
      "Username": "<YOUR_EMAIL_ADDRESS>",
      "Password": "<YOUR_APP_PASSWORD>",
      "FromAddress": "<YOUR_EMAIL_ADDRESS>",
      "ToAddress": "<RECIPIENT_EMAIL_ADDRESS>"
    },
    "MarketData": {
      "Enabled": true,
      "SymbolMappings": []
    },
    "News": {
      "Enabled": true,
      "MaxItemsPerFeed": 5,
      "FeedUrls": []
    },
    "Scheduler": {
      "CronExpression": "0 8 * * *"
    },
    "Topics": [
      {
        "Name": "AI Industry News",
        "Description": "Latest developments in artificial intelligence, large language models, and AI companies."
      },
      {
        "Name": "Technology Trends",
        "Description": "Emerging technologies, software engineering, and tech industry news."
      }
    ]
  }
}
